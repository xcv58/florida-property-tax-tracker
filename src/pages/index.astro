---
import BallotRunway from '../components/BallotRunway.astro';
import SourceLink from '../components/SourceLink.astro';
import StatusHero from '../components/StatusHero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSources, overview, status } from '../utils/data';
import { site, withBase } from '../utils/site';

const briefSources = getSources(overview.brief.source_ids);
const ballotSources = getSources(['fl-dos-constitutional-amendments', 'flsenate-constitution-article-xi']);
const trackerDataset = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'Florida Property Tax Tracker data',
  description: site.description,
  url: site.url,
  dateModified: status.last_verified,
  keywords: [
    'Florida property tax',
    'HJR 203',
    'constitutional amendment',
    'Florida Legislature',
    'county impact data',
  ],
  creator: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
};
---

<BaseLayout jsonLd={trackerDataset}>
  <StatusHero maxSources={3} sourceMode="summary" hidePanel />

  <div class="shell">
    <BallotRunway compact />
  </div>

  <div class="shell page-stack">
    <section class="overview-grid" aria-label="Current tracker overview">
      <article class="section-block overview-brief">
        <p class="terminal-label">&gt; {overview.brief.eyebrow}</p>
        <h2>{overview.brief.heading}</h2>
        <p class="lede">{overview.brief.body}</p>
        <div class="source-row source-row--trimmed">
          {briefSources.map((source) => <SourceLink source={source} compact />)}
        </div>
      </article>
      <aside class="section-block status-legend" aria-label="Status color legend">
        <p class="terminal-label">&gt; status_colors</p>
        <h2>Color Key</h2>
        <div class="legend-list">
          {
            overview.status_legend.map((item) => (
              <div class={`legend-item legend-item--${item.status}`}>
                <span aria-hidden="true"></span>
                <p><strong>{item.label}</strong>{item.meaning}</p>
              </div>
            ))
          }
        </div>
      </aside>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <div>
          <p class="terminal-label">&gt; next_decisions</p>
          <h2>What Happens Next</h2>
        </div>
      </div>
      <div class="next-panel-grid">
        {
          overview.next_panels.map((panel) => (
            <article class={`next-panel next-panel--${panel.status}`}>
              <p class="terminal-label">&gt; {panel.label}</p>
              <strong>{panel.value}</strong>
              <p>{panel.body}</p>
            </article>
          ))
        }
      </div>
      <div class="known-unknowns">
        <h3>Known Unknowns</h3>
        <ul>
          {overview.known_unknowns.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>

    <section class="section-block">
      <div class="section-heading">
        <div>
          <p class="terminal-label">&gt; choose_depth</p>
          <h2>Choose Your View</h2>
        </div>
      </div>
      <div class="depth-link-grid">
        {
          overview.depth_links.map((item) => (
            <article class="depth-link-card">
              <p class="terminal-label">&gt; {item.label}</p>
              <h3><a href={withBase(item.href)}>{item.title}</a></h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section-block compact-evidence">
      <div class="section-heading">
        <div>
          <p class="terminal-label">&gt; ballot_path_sources</p>
          <h2>Ballot Path Evidence</h2>
        </div>
        <a class="text-link" href={withBase('/details/')}>Open details</a>
      </div>
      <p>A legislative constitutional amendment would still need to move through the constitutional-amendment path and receive voter approval before changing the Florida Constitution.</p>
      <div class="source-row">
        {ballotSources.map((source) => <SourceLink source={source} compact />)}
      </div>
    </section>
  </div>
</BaseLayout>
