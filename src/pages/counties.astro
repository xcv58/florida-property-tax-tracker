---
import CountyTable from '../components/CountyTable.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Advanced County Data | Florida Property Tax Tracker" description="Searchable county impact table for Florida property tax proposals.">
  <div class="shell page-intro">
    <p class="terminal-label">&gt; counties</p>
    <h1>Advanced County Data</h1>
    <p>County impacts remain blank until a source identifies a proposal version, estimate type, and verification date.</p>
  </div>
  <div class="shell">
    <CountyTable />
  </div>
</BaseLayout>
