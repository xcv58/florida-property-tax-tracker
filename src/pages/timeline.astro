---
import PathTimeline from '../components/PathTimeline.astro';
import Timeline from '../components/Timeline.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Timeline | Florida Property Tax Tracker" description="Legislative and political timeline for Florida property tax elimination proposals.">
  <div class="shell page-intro">
    <p class="terminal-label">&gt; timeline</p>
    <h1>Timeline</h1>
    <p>Chronological source-backed events for active, dead, and related proposals.</p>
  </div>
  <div class="shell">
    <PathTimeline title="Procedural Dependency Map" />
    <Timeline />
  </div>
</BaseLayout>
