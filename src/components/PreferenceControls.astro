---

<div class="preference-controls" aria-label="Display preferences">
  <label class="preference-control preference-control--theme">
    <span>Theme</span>
    <select data-theme-select aria-label="Theme">
      <option value="system">System</option>
      <option value="light">Light</option>
      <option value="dark">Dark</option>
    </select>
  </label>
  <label class="preference-control preference-control--language">
    <span>Language</span>
    <select data-language-select aria-label="Language">
      <option value="en">English</option>
      <option value="es">Español</option>
    </select>
  </label>
</div>
