---
import { getSources, proposals as defaultProposals } from '../utils/data';
import SourceLink from './SourceLink.astro';

const { items = defaultProposals } = Astro.props;
---

<section class="section-block">
  <div class="section-heading">
    <div>
      <p class="terminal-label">&gt; proposals</p>
      <h2>Proposal Tracker</h2>
    </div>
  </div>
  <div class="table-frame">
    <table>
      <caption>
        Active, dead, and related proposals materially connected to the property-tax elimination debate.
      </caption>
      <thead>
        <tr>
          <th scope="col">Proposal</th>
          <th scope="col">Type</th>
          <th scope="col">Status</th>
          <th scope="col">Chamber</th>
          <th scope="col">Sponsor</th>
          <th scope="col">Last action</th>
          <th scope="col">Current relevance</th>
          <th scope="col">Source</th>
        </tr>
      </thead>
      <tbody>
        {
          items.map((proposal) => {
            const proposalSources = getSources(proposal.source_ids);
            return (
              <tr>
                <th scope="row" data-label="Proposal">
                  <strong>{proposal.name}</strong>
                  <span>{proposal.title}</span>
                </th>
                <td data-label="Type">{proposal.proposal_type.replaceAll('_', ' ')}</td>
                <td data-label="Status"><span class={`badge badge--${proposal.status}`}>{proposal.status.replaceAll('_', ' ')}</span></td>
                <td data-label="Chamber">{proposal.chamber}</td>
                <td data-label="Sponsor">{proposal.sponsor}</td>
                <td data-label="Last action">{proposal.last_action_date}: {proposal.last_action}</td>
                <td data-label="Current relevance">{proposal.current_relevance}</td>
                <td data-label="Source">
                  <div class="source-row">
                    {proposalSources.map((source) => <SourceLink source={source} compact />)}
                  </div>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>
