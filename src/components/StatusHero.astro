---
import { getClaims, getSources, status as defaultStatus } from '../utils/data';
import SourceLink from './SourceLink.astro';

const trackerStatus = Astro.props.status ?? defaultStatus;
const heroClaims = getClaims(trackerStatus.claim_ids);
const sourceIds = Array.from(new Set(heroClaims.flatMap((claim) => claim.source_ids)));
const heroSources = getSources(sourceIds);
---

<section class="hero-section">
  <div class="shell hero-grid">
    <div class="hero-copy">
      <h1>{trackerStatus.site_title}</h1>
      <p class="hero-subtitle">{trackerStatus.subtitle}</p>
      <div class="status-strip" aria-label="Current tracker status">
        <span class="status-dot" aria-hidden="true"></span>
        <span>Current status</span>
        <strong>{trackerStatus.current_status_label}</strong>
      </div>
      <p class="hero-summary">{trackerStatus.current_status_summary}</p>
    </div>
    <aside class="hero-panel" aria-label="Current verification details">
      <div>
        <p class="terminal-label">&gt; last_verified</p>
        <strong>{trackerStatus.last_verified}</strong>
      </div>
      <div>
        <p class="terminal-label">&gt; latest_update</p>
        <p>{trackerStatus.latest_update}</p>
      </div>
      <div>
        <p class="terminal-label">&gt; expected_next</p>
        <p>{trackerStatus.expected_next}</p>
      </div>
    </aside>
  </div>
  <div class="shell hero-sources">
    <p>Source records for this status</p>
    <div class="source-row">
      {heroSources.map((source) => <SourceLink source={source} compact />)}
    </div>
  </div>
</section>
