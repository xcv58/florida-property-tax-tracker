---
import '../styles/global.css';
import PreferenceControls from '../components/PreferenceControls.astro';
import { translationTemplates, translations } from '../utils/translations';
import { status } from '../utils/data';
import {
  absoluteCanonicalUrl,
  canonicalUrlForPath,
  correctionUrl,
  site,
  withBase,
  withoutBase,
} from '../utils/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  type?: string;
  lastUpdated?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Florida Property Tax Tracker | 2026 Elimination Proposals and Related Reforms',
  description = site.description,
  image = site.defaultImage,
  noindex = false,
  type = 'website',
  lastUpdated = status.last_verified,
  jsonLd = [],
} = Astro.props;
const canonical = canonicalUrlForPath(Astro.url.pathname);
const imageUrl = absoluteCanonicalUrl(image);
const robots = noindex || !site.indexing
  ? 'noindex, follow'
  : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1';
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${site.url}/#website`,
    name: site.name,
    url: site.url,
    description: site.description,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    isPartOf: { '@id': `${site.url}/#website` },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: imageUrl,
      width: 1200,
      height: 630,
    },
    dateModified: lastUpdated,
    inLanguage: 'en-US',
  },
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]),
];
const navItems = [
  ['Overview', '/'],
  ['Details', '/details/'],
  ['Timeline', '/timeline/'],
  ['Counties', '/counties/'],
  ['Sources', '/sources/'],
  ['Methodology', '/methodology/'],
  ['About', '/about/'],
];
const currentPath = withoutBase(Astro.url.pathname);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={robots} />
    <meta name="application-name" content={site.name} />
    <meta name="apple-mobile-web-app-title" content={site.name} />
    <meta name="theme-color" content="#f8f6ee" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#111614" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('fptt-theme') || 'system';
          const language = localStorage.getItem('fptt-language') || 'en';
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
          document.documentElement.lang = language;
          if (language !== 'en') document.documentElement.dataset.lang = language;
        } catch {
          document.documentElement.lang = 'en';
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="icon" href={withBase('/favicon.ico')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <link rel="alternate" type="application/rss+xml" title={`${site.name} update feed`} href={absoluteCanonicalUrl('/feed.xml')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:secure_url" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Florida Property Tax Tracker" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content="Florida Property Tax Tracker" />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to main content</a>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href={withBase('/')} aria-label="Florida Property Tax Tracker home">
          <span class="brand-mark" aria-hidden="true">FL</span>
          <span>
            <strong>Florida Property Tax Tracker</strong>
            <small>Source-backed civic status</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="Primary navigation">
          {
            navItems.map(([label, href]) => (
              <a href={withBase(href)} class={currentPath === href ? 'is-active' : ''}>
                {label}
              </a>
            ))
          }
        </nav>
        <PreferenceControls />
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <p>
          Florida Property Tax Tracker is a neutral civic tracking project. It is not affiliated with
          the State of Florida, the Florida Legislature, any county government, or any advocacy
          organization. All factual claims are linked to source records.
        </p>
        <a href={correctionUrl}>See an error? Submit a correction with a source.</a>
      </div>
    </footer>
    <button
      class="back-to-top"
      type="button"
      aria-label="Back to top"
      aria-hidden="true"
      tabindex="-1"
      data-back-to-top
    >
      <span class="back-to-top-arrow" aria-hidden="true"></span>
      <span>Top</span>
    </button>
    <script define:vars={{ translations, translationTemplates }}>
      (() => {
        const themeButtons = [...document.querySelectorAll('[data-theme-button]')];
        const languageSelect = document.querySelector('[data-language-select]');
        const backToTopButton = document.querySelector('[data-back-to-top]');
        const textOriginals = new WeakMap();
        const attrOriginals = new WeakMap();
        const attrNames = ['aria-label', 'placeholder', 'title', 'data-label'];

        function storedValue(key, fallback) {
          try {
            return localStorage.getItem(key) || fallback;
          } catch {
            return fallback;
          }
        }

        function setStoredValue(key, value) {
          try {
            localStorage.setItem(key, value);
          } catch {
            // Ignore storage failures; controls still work for the current page.
          }
        }

        function applyTheme(theme) {
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          } else {
            delete document.documentElement.dataset.theme;
          }
          themeButtons.forEach((button) => {
            const isActive = button.dataset.themeValue === theme;
            button.classList.toggle('is-active', isActive);
            button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          });
        }

        function normalize(text) {
          return text.replace(/\s+/g, ' ').trim();
        }

        function withOriginalWhitespace(original, translated) {
          const leading = original.match(/^\s*/)?.[0] ?? '';
          const trailing = original.match(/\s*$/)?.[0] ?? '';
          return `${leading}${translated}${trailing}`;
        }

        function translateTextNodes(language) {
          const dictionary = translations[language] ?? {};
          const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
            acceptNode(node) {
              if (!node.nodeValue || !normalize(node.nodeValue)) return NodeFilter.FILTER_REJECT;
              const parent = node.parentElement;
              if (!parent) return NodeFilter.FILTER_REJECT;
              if (parent.closest('script, style, textarea, [data-no-translate]')) {
                return NodeFilter.FILTER_REJECT;
              }
              return NodeFilter.FILTER_ACCEPT;
            },
          });

          const nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);
          nodes.forEach((node) => {
            if (!textOriginals.has(node)) textOriginals.set(node, node.nodeValue ?? '');
            const original = textOriginals.get(node) ?? '';
            const key = normalize(original);
            const translated = language === 'en' ? key : dictionary[key];
            node.nodeValue = translated ? withOriginalWhitespace(original, translated) : original;
          });
        }

        function translateAttributes(language) {
          const dictionary = translations[language] ?? {};
          attrNames.forEach((attr) => {
            document.querySelectorAll(`[${attr}]`).forEach((element) => {
              let originalMap = attrOriginals.get(element);
              if (!originalMap) {
                originalMap = {};
                attrOriginals.set(element, originalMap);
              }
              if (!originalMap[attr]) originalMap[attr] = element.getAttribute(attr) || '';
              const original = originalMap[attr];
              const key = normalize(original);
              const translated = language === 'en' ? key : dictionary[key];
              element.setAttribute(attr, translated || original);
            });
          });
        }

        function applyTemplates(language) {
          const templates = translationTemplates[language] ?? {};
          document.querySelectorAll('[data-i18n-template]').forEach((element) => {
            const template = element.dataset.i18nTemplate;
            const count = element.dataset.count || '';
            if (language === 'en') {
              element.textContent = element.dataset.i18nDefault || element.textContent;
              return;
            }
            if (template && templates[template]) {
              element.textContent = templates[template].replace('{count}', count);
            }
          });
        }

        function applyLanguage(language) {
          const nextLanguage = translations[language] || language === 'en' ? language : 'en';
          document.documentElement.lang = nextLanguage;
          if (nextLanguage === 'en') delete document.documentElement.dataset.lang;
          else document.documentElement.dataset.lang = nextLanguage;
          if (languageSelect) languageSelect.value = nextLanguage;
          translateTextNodes(nextLanguage);
          translateAttributes(nextLanguage);
          applyTemplates(nextLanguage);
        }

        const initialTheme = storedValue('fptt-theme', 'system');
        const initialLanguage = storedValue('fptt-language', 'en');
        applyTheme(initialTheme);
        applyLanguage(initialLanguage);

        themeButtons.forEach((button) => {
          button.addEventListener('click', () => {
            const nextTheme = button.dataset.themeValue || 'system';
            setStoredValue('fptt-theme', nextTheme);
            applyTheme(nextTheme);
          });
        });

        languageSelect?.addEventListener('change', () => {
          const nextLanguage = languageSelect.value;
          setStoredValue('fptt-language', nextLanguage);
          applyLanguage(nextLanguage);
        });

        if (backToTopButton) {
          const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

          function updateBackToTop() {
            const isVisible = window.scrollY > 480;
            backToTopButton.classList.toggle('is-visible', isVisible);
            backToTopButton.setAttribute('aria-hidden', isVisible ? 'false' : 'true');
            backToTopButton.tabIndex = isVisible ? 0 : -1;
          }

          backToTopButton.addEventListener('click', () => {
            window.scrollTo({
              top: 0,
              behavior: prefersReducedMotion.matches ? 'auto' : 'smooth',
            });
          });

          updateBackToTop();
          window.addEventListener('scroll', updateBackToTop, { passive: true });
        }
      })();
    </script>
  </body>
</html>
